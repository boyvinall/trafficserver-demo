{
  "title": "ATS Server Metrics",
  "uid": "ats-cluster",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Memory Usage (RSS)",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "targets": [
        {
          "expr": "proxy_process_traffic_server_memory_rss",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 500000000, "color": "yellow"},
              {"value": 1000000000, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Current Client Connections",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "targets": [
        {
          "expr": "proxy_process_http_current_client_connections",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Current Server Connections",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "targets": [
        {
          "expr": "proxy_process_http_current_server_connections",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active Transactions",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "targets": [
        {
          "expr": "proxy_process_http_current_client_transactions",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Cache Hit Rate",
      "gridPos": {"h": 4, "w": 6, "x": 16, "y": 1},
      "targets": [
        {
          "expr": "100 * proxy_process_cache_total_hits / (proxy_process_cache_total_hits + proxy_process_cache_total_misses)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "red"},
              {"value": 30, "color": "yellow"},
              {"value": 60, "color": "green"}
            ]
          },
          "decimals": 1
        }
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "HTTP Traffic & Performance",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Request Rate",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "targets": [
        {
          "expr": "rate(proxy_process_http_incoming_requests[1m])",
          "legendFormat": "Incoming",
          "refId": "A"
        },
        {
          "expr": "rate(proxy_process_http_completed_requests[1m])",
          "legendFormat": "Completed",
          "refId": "B"
        },
        {
          "expr": "rate(proxy_process_http_outgoing_requests[1m])",
          "legendFormat": "Outgoing",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Bandwidth",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "targets": [
        {
          "expr": "rate(proxy_process_user_agent_total_bytes[1m])",
          "legendFormat": "User Agent",
          "refId": "A"
        },
        {
          "expr": "rate(proxy_process_origin_server_total_bytes[1m])",
          "legendFormat": "Origin Server",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 13,
      "type": "bargauge",
      "title": "Response Status Codes",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 14},
      "targets": [
        {
          "expr": "proxy_process_http_2xx_responses",
          "legendFormat": "2xx Success",
          "refId": "A"
        },
        {
          "expr": "proxy_process_http_3xx_responses",
          "legendFormat": "3xx Redirect",
          "refId": "B"
        },
        {
          "expr": "proxy_process_http_4xx_responses",
          "legendFormat": "4xx Client Error",
          "refId": "C"
        },
        {
          "expr": "proxy_process_http_5xx_responses",
          "legendFormat": "5xx Server Error",
          "refId": "D"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"}
            ]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "4xx Client Error"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]
          },
          {
            "matcher": {"id": "byName", "options": "5xx Server Error"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]
          }
        ]
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "HTTP Method Distribution",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 14},
      "targets": [
        {
          "expr": "rate(proxy_process_http_get_requests[1m])",
          "legendFormat": "GET",
          "refId": "A"
        },
        {
          "expr": "rate(proxy_process_http_post_requests[1m])",
          "legendFormat": "POST",
          "refId": "B"
        },
        {
          "expr": "rate(proxy_process_http_head_requests[1m])",
          "legendFormat": "HEAD",
          "refId": "C"
        },
        {
          "expr": "rate(proxy_process_http_put_requests[1m])",
          "legendFormat": "PUT",
          "refId": "D"
        },
        {
          "expr": "rate(proxy_process_http_delete_requests[1m])",
          "legendFormat": "DELETE",
          "refId": "E"
        },
        {
          "expr": "rate(proxy_process_http_connect_requests[1m])",
          "legendFormat": "CONNECT",
          "refId": "F"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {"mode": "normal"}
          }
        }
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Transaction Time",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 14},
      "targets": [
        {
          "expr": "rate(proxy_process_http_total_transactions_time[1m]) / rate(proxy_process_http_completed_requests[1m]) / 1000",
          "legendFormat": "Avg Transaction Time",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 100, "color": "yellow"},
              {"value": 500, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Cache Performance",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 22},
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Cache Operations Rate",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 23},
      "targets": [
        {
          "expr": "rate(proxy_process_http_cache_hit_fresh[1m])",
          "legendFormat": "Hit Fresh",
          "refId": "A"
        },
        {
          "expr": "rate(proxy_process_http_cache_hit_mem_fresh[1m])",
          "legendFormat": "Hit Memory Fresh",
          "refId": "B"
        },
        {
          "expr": "rate(proxy_process_http_cache_hit_revalidated[1m])",
          "legendFormat": "Hit Revalidated",
          "refId": "C"
        },
        {
          "expr": "rate(proxy_process_http_cache_miss_cold[1m])",
          "legendFormat": "Miss Cold",
          "refId": "D"
        },
        {
          "expr": "rate(proxy_process_http_cache_miss_changed[1m])",
          "legendFormat": "Miss Changed",
          "refId": "E"
        },
        {
          "expr": "rate(proxy_process_http_cache_miss_client_not_cacheable[1m])",
          "legendFormat": "Miss Not Cacheable",
          "refId": "F"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Cache Storage",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 23},
      "targets": [
        {
          "expr": "proxy_process_cache_bytes_used",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "proxy_process_cache_bytes_total",
          "legendFormat": "Total",
          "refId": "B"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 23,
      "type": "gauge",
      "title": "Cache Utilization",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 23},
      "targets": [
        {
          "expr": "100 * proxy_process_cache_bytes_used / proxy_process_cache_bytes_total",
          "refId": "A"
        }
      ],
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 70, "color": "yellow"},
              {"value": 90, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 24,
      "type": "stat",
      "title": "RAM Cache",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 27},
      "targets": [
        {
          "expr": "proxy_process_cache_ram_cache_bytes_used",
          "legendFormat": "RAM Used",
          "refId": "A"
        },
        {
          "expr": "proxy_process_cache_ram_cache_total_bytes",
          "legendFormat": "RAM Total",
          "refId": "B"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 25,
      "type": "timeseries",
      "title": "RAM Cache Hit Rate",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 27},
      "targets": [
        {
          "expr": "rate(proxy_process_cache_ram_cache_hits[1m])",
          "legendFormat": "Hits",
          "refId": "A"
        },
        {
          "expr": "rate(proxy_process_cache_ram_cache_misses[1m])",
          "legendFormat": "Misses",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 26,
      "type": "timeseries",
      "title": "Cache I/O",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 31},
      "targets": [
        {
          "expr": "rate(proxy_process_cache_aio_KB_read[1m]) * 1024",
          "legendFormat": "Read",
          "refId": "A"
        },
        {
          "expr": "rate(proxy_process_cache_aio_KB_write[1m]) * 1024",
          "legendFormat": "Write",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 27,
      "type": "timeseries",
      "title": "Cache Operations",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 31},
      "targets": [
        {
          "expr": "rate(proxy_process_cache_read_success[1m])",
          "legendFormat": "Read Success",
          "refId": "A"
        },
        {
          "expr": "rate(proxy_process_cache_write_success[1m])",
          "legendFormat": "Write Success",
          "refId": "B"
        },
        {
          "expr": "rate(proxy_process_cache_update_success[1m])",
          "legendFormat": "Update Success",
          "refId": "C"
        },
        {
          "expr": "rate(proxy_process_cache_read_failure[1m])",
          "legendFormat": "Read Failure",
          "refId": "D"
        },
        {
          "expr": "rate(proxy_process_cache_write_failure[1m])",
          "legendFormat": "Write Failure",
          "refId": "E"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "Connections & Network",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 39},
      "collapsed": false
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Client Connections",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40},
      "targets": [
        {
          "expr": "proxy_process_http_current_client_connections",
          "legendFormat": "Current",
          "refId": "A"
        },
        {
          "expr": "proxy_process_http_current_active_client_connections",
          "legendFormat": "Active",
          "refId": "B"
        },
        {
          "expr": "rate(proxy_process_http_total_client_connections[1m])",
          "legendFormat": "New Rate",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Server Connections",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 40},
      "targets": [
        {
          "expr": "proxy_process_http_current_server_connections",
          "legendFormat": "Current",
          "refId": "A"
        },
        {
          "expr": "rate(proxy_process_http_total_server_connections[1m])",
          "legendFormat": "New Rate",
          "refId": "B"
        },
        {
          "expr": "proxy_process_http_pooled_server_connections",
          "legendFormat": "Pooled",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 33,
      "type": "stat",
      "title": "Connection Protocol Distribution",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 48},
      "targets": [
        {
          "expr": "proxy_process_http_total_client_connections_ipv4",
          "legendFormat": "IPv4",
          "refId": "A"
        },
        {
          "expr": "proxy_process_http_total_client_connections_ipv6",
          "legendFormat": "IPv6",
          "refId": "B"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 34,
      "type": "timeseries",
      "title": "Network I/O Operations",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 48},
      "targets": [
        {
          "expr": "rate(proxy_process_net_calls_to_read[1m])",
          "legendFormat": "Read Calls",
          "refId": "A"
        },
        {
          "expr": "rate(proxy_process_net_calls_to_write[1m])",
          "legendFormat": "Write Calls",
          "refId": "B"
        },
        {
          "expr": "rate(proxy_process_net_calls_to_read_nodata[1m])",
          "legendFormat": "Read No Data",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 35,
      "type": "timeseries",
      "title": "Network Throughput",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 48},
      "targets": [
        {
          "expr": "rate(proxy_process_net_read_bytes[1m])",
          "legendFormat": "Read",
          "refId": "A"
        },
        {
          "expr": "rate(proxy_process_net_write_bytes[1m])",
          "legendFormat": "Write",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 40,
      "type": "row",
      "title": "Event Loop Performance",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 54},
      "collapsed": false
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Event Loop Count (10s window)",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 55},
      "targets": [
        {
          "expr": "rate(proxy_process_eventloop_count_10s[1m])",
          "legendFormat": "Loop Count",
          "refId": "A"
        },
        {
          "expr": "rate(proxy_process_eventloop_events_10s[1m])",
          "legendFormat": "Events",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 42,
      "type": "stat",
      "title": "Event Loop Stats (10s)",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 55},
      "targets": [
        {
          "expr": "proxy_process_eventloop_events_min_10s",
          "legendFormat": "Events Min",
          "refId": "A"
        },
        {
          "expr": "proxy_process_eventloop_events_max_10s",
          "legendFormat": "Events Max",
          "refId": "B"
        },
        {
          "expr": "proxy_process_eventloop_time_min_10s / 1000",
          "legendFormat": "Time Min (ms)",
          "refId": "C"
        },
        {
          "expr": "proxy_process_eventloop_time_max_10s / 1000",
          "legendFormat": "Time Max (ms)",
          "refId": "D"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "vertical"
      }
    },
    {
      "id": 43,
      "type": "stat",
      "title": "Max Wait Times (10s)",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 55},
      "targets": [
        {
          "expr": "proxy_process_eventloop_drain_queue_max_10s / 1000",
          "legendFormat": "Drain Queue (ms)",
          "refId": "A"
        },
        {
          "expr": "proxy_process_eventloop_io_wait_max_10s / 1000",
          "legendFormat": "I/O Wait (ms)",
          "refId": "B"
        },
        {
          "expr": "proxy_process_eventloop_io_work_max_10s / 1000",
          "legendFormat": "I/O Work (ms)",
          "refId": "C"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "vertical"
      },
      "fieldConfig": {
        "defaults": {
