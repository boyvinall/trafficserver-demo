{
  "title": "HAProxy Metrics",
  "uid": "haproxy",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Current Sessions",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "targets": [
        {
          "expr": "sum(haproxy_frontend_current_sessions)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Requests/sec",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "targets": [
        {
          "expr": "sum(rate(haproxy_frontend_http_requests_total[1m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Backend Servers Up",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "targets": [
        {
          "expr": "sum(haproxy_server_up)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "red"},
              {"value": 1, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Bandwidth",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "targets": [
        {
          "expr": "sum(rate(haproxy_frontend_bytes_in_total[1m]) + rate(haproxy_frontend_bytes_out_total[1m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "decimals": 1
        }
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Frontend Metrics",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Frontend Request Rate",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "targets": [
        {
          "expr": "rate(haproxy_frontend_http_requests_total[1m])",
          "legendFormat": "{{proxy}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Frontend Sessions",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "targets": [
        {
          "expr": "haproxy_frontend_current_sessions",
          "legendFormat": "{{proxy}} - Current",
          "refId": "A"
        },
        {
          "expr": "rate(haproxy_frontend_sessions_total[1m])",
          "legendFormat": "{{proxy}} - Rate",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Frontend Bytes In/Out",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "targets": [
        {
          "expr": "rate(haproxy_frontend_bytes_in_total[1m])",
          "legendFormat": "{{proxy}} - In",
          "refId": "A"
        },
        {
          "expr": "rate(haproxy_frontend_bytes_out_total[1m])",
          "legendFormat": "{{proxy}} - Out",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Frontend HTTP Response Codes",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "targets": [
        {
          "expr": "rate(haproxy_frontend_http_responses_total{code=\"2xx\"}[1m])",
          "legendFormat": "{{proxy}} - 2xx",
          "refId": "A"
        },
        {
          "expr": "rate(haproxy_frontend_http_responses_total{code=\"3xx\"}[1m])",
          "legendFormat": "{{proxy}} - 3xx",
          "refId": "B"
        },
        {
          "expr": "rate(haproxy_frontend_http_responses_total{code=\"4xx\"}[1m])",
          "legendFormat": "{{proxy}} - 4xx",
          "refId": "C"
        },
        {
          "expr": "rate(haproxy_frontend_http_responses_total{code=\"5xx\"}[1m])",
          "legendFormat": "{{proxy}} - 5xx",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {"mode": "normal"}
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byRegexp", "options": ".*5xx.*"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]
          },
          {
            "matcher": {"id": "byRegexp", "options": ".*4xx.*"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]
          }
        ]
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Backend Metrics",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 22},
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Backend Response Time",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 23},
      "targets": [
        {
          "expr": "haproxy_backend_response_time_average_seconds",
          "legendFormat": "{{proxy}} - Avg",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 0.5, "color": "yellow"},
              {"value": 1, "color": "red"}
            ]
          }
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Backend Connections",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 23},
      "targets": [
        {
          "expr": "haproxy_backend_current_sessions",
          "legendFormat": "{{proxy}} - Current Sessions",
          "refId": "A"
        },
        {
          "expr": "haproxy_backend_current_queue",
          "legendFormat": "{{proxy}} - Queue",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Backend Request Rate",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 31},
      "targets": [
        {
          "expr": "rate(haproxy_backend_http_requests_total[1m])",
