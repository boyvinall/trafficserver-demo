        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 34,
      "type": "timeseries",
      "title": "Server Queue Depth",
