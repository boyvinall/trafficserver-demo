    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "Backend HTTP Response Codes",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 31},
      "targets": [
        {
          "expr": "rate(haproxy_backend_http_responses_total{code=\"2xx\"}[1m])",
          "legendFormat": "{{proxy}} - 2xx",
          "refId": "A"
        },
        {
          "expr": "rate(haproxy_backend_http_responses_total{code=\"3xx\"}[1m])",
          "legendFormat": "{{proxy}} - 3xx",
          "refId": "B"
        },
        {
          "expr": "rate(haproxy_backend_http_responses_total{code=\"4xx\"}[1m])",
          "legendFormat": "{{proxy}} - 4xx",
          "refId": "C"
        },
        {
          "expr": "rate(haproxy_backend_http_responses_total{code=\"5xx\"}[1m])",
