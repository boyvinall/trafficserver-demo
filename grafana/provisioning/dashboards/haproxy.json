      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 40,
      "type": "row",
      "title": "Error Tracking",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 56},
      "collapsed": false
    },
