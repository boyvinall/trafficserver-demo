    {
      "id": 50,
      "type": "row",
      "title": "Session Limits & Capacity",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 71},
      "collapsed": false
    },
    {
      "id": 51,
      "type": "gauge",
      "title": "Frontend Session Utilization",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 72},
      "targets": [
        {
          "expr": "100 * haproxy_frontend_current_sessions / haproxy_frontend_limit_sessions",
          "legendFormat": "{{proxy}}",
          "refId": "A"
        }
      ],
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 70, "color": "yellow"},
              {"value": 90, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 52,
      "type": "gauge",
