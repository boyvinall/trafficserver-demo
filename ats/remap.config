# Map traffic from HAProxy to internal origin servers
# These use Docker service names for DNS resolution

# Web origin - HTML pages
map http://localhost/ http://origin-web:9001/
map http://localhost:8080/ http://origin-web:9001/
map http://localhost:8081/ http://origin-web:9001/
map http://localhost:8082/ http://origin-web:9001/
map http://localhost:8083/ http://origin-web:9001/

# API origin - JSON endpoints
map http://localhost/api/ http://origin-api:9002/api/
map http://localhost:8080/api/ http://origin-api:9002/api/
map http://localhost:8081/api/ http://origin-api:9002/api/
map http://localhost:8082/api/ http://origin-api:9002/api/
map http://localhost:8083/api/ http://origin-api:9002/api/

# Static origin - CSS/JS/images
map http://localhost/static/ http://origin-static:9003/
map http://localhost:8080/static/ http://origin-static:9003/
map http://localhost:8081/static/ http://origin-static:9003/
map http://localhost:8082/static/ http://origin-static:9003/
map http://localhost:8083/static/ http://origin-static:9003/