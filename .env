# ATS Cluster Environment Configuration

# Project Name
COMPOSE_PROJECT_NAME=ats-cluster

# Ports
HAPROXY_HTTP_PORT=80
HAPROXY_STATS_PORT=8404
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Grafana Credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ATS Configuration
ATS_CACHE_SIZE=500G
ATS_LOG_LEVEL=info

# Monitoring
PROMETHEUS_RETENTION=7d
PROMETHEUS_SCRAPE_INTERVAL=15s
